<wxs module="utils">
module.exports = {
  categoryName: function(cat) {
    var map = { suggestion: '建议', bug: 'Bug', complaint: '投诉', other: '其他' }
    return map[cat] || cat
  },
  statusName: function(s) {
    var map = { pending: '待处理', processing: '处理中', resolved: '已回复', closed: '已关闭' }
    return map[s] || s
  }
}
</wxs>

<view class="container">
  <!-- 提交表单区 -->
  <view class="form-section">
    <view class="section-title">提交反馈</view>

    <!-- 反馈类型 -->
    <view class="category-group">
      <view
        class="category-btn {{selectedCategory === item.key ? 'active' : ''}}"
        wx:for="{{categories}}"
        wx:key="key"
        data-key="{{item.key}}"
        bindtap="selectCategory"
      >
        {{item.name}}
      </view>
    </view>

    <!-- 内容输入 -->
    <view class="textarea-wrap">
      <textarea
        class="content-textarea"
        placeholder="请详细描述您的反馈（至少10个字）"
        value="{{content}}"
        bindinput="onContentInput"
        maxlength="500"
      />
      <view class="word-count">{{contentLength}}/500</view>
    </view>

    <!-- 图片上传 -->
    <view class="image-section">
      <view class="image-list">
        <view class="image-item" wx:for="{{images}}" wx:key="*this">
          <image class="upload-image" src="{{item}}" mode="aspectFill" bindtap="previewImage" data-url="{{item}}" />
          <view class="image-delete" bindtap="removeImage" data-index="{{index}}">×</view>
        </view>
        <view class="image-add" wx:if="{{images.length < 3}}" bindtap="chooseImage">
          <text class="add-icon">+</text>
          <text class="add-text">添加图片</text>
        </view>
      </view>
      <view class="image-tip">最多上传3张图片</view>
    </view>

    <!-- 联系方式 -->
    <view class="contact-wrap">
      <input class="contact-input" placeholder="联系方式（选填，方便我们回复您）" value="{{contact}}" bindinput="onContactInput" maxlength="50" />
    </view>

    <!-- 提交按钮 -->
    <button class="btn-submit" bindtap="submitFeedback" loading="{{submitting}}" disabled="{{submitting}}">提交反馈</button>
  </view>

  <!-- 反馈历史区 -->
  <view class="history-section" wx:if="{{feedbackList.length > 0}}">
    <view class="section-title">我的反馈</view>

    <view class="feedback-card" wx:for="{{feedbackList}}" wx:key="id" bindtap="toggleExpand" data-id="{{item.id}}">
      <view class="feedback-header">
        <view class="feedback-category">{{utils.categoryName(item.category)}}</view>
        <view class="feedback-status {{item.status}}">{{utils.statusName(item.status)}}</view>
      </view>
      <view class="feedback-content-preview">{{item.content}}</view>
      <view class="feedback-time">{{item.created_at}}</view>

      <!-- 展开详情 -->
      <view class="feedback-detail" wx:if="{{expandedId === item.id}}">
        <view class="detail-content">{{item.content}}</view>
        <view class="reply-card" wx:if="{{item.admin_reply}}">
          <view class="reply-label">管理员回复</view>
          <view class="reply-content">{{item.admin_reply}}</view>
          <view class="reply-time" wx:if="{{item.reply_time}}">{{item.reply_time}}</view>
        </view>
        <view class="no-reply" wx:if="{{!item.admin_reply && item.status === 'pending'}}">
          <text>等待处理中...</text>
        </view>
      </view>

      <view class="expand-hint">
        <text wx:if="{{expandedId === item.id}}">收起</text>
        <text wx:else>查看详情</text>
      </view>
    </view>
  </view>
</view>
