.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 20rpx;
  padding-bottom: 60rpx;
}

/* 通用标题 */
.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
}

/* 表单区域 */
.form-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

/* 反馈类型按钮组 */
.category-group {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.category-btn {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 28rpx;
  color: #666;
  background: #f5f5f5;
  border-radius: 24rpx;
  transition: all 0.2s;
}

.category-btn.active {
  background: #1A5D3A;
  color: #fff;
}

/* 文本输入 */
.textarea-wrap {
  position: relative;
  margin-bottom: 24rpx;
}

.content-textarea {
  width: 100%;
  height: 240rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.word-count {
  position: absolute;
  bottom: 16rpx;
  right: 20rpx;
  font-size: 24rpx;
  color: #ccc;
}

/* 图片上传 */
.image-section {
  margin-bottom: 24rpx;
}

.image-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.image-item {
  position: relative;
  width: 200rpx;
  height: 200rpx;
}

.upload-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
}

.image-delete {
  position: absolute;
  top: -12rpx;
  right: -12rpx;
  width: 40rpx;
  height: 40rpx;
  line-height: 36rpx;
  text-align: center;
  background: #ff4d4f;
  color: #fff;
  font-size: 28rpx;
  border-radius: 50%;
}

.image-add {
  width: 200rpx;
  height: 200rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #f5f5f5;
  border: 2rpx dashed #ddd;
  border-radius: 12rpx;
}

.add-icon {
  font-size: 48rpx;
  color: #999;
  line-height: 1;
}

.add-text {
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
}

.image-tip {
  font-size: 24rpx;
  color: #ccc;
  margin-top: 12rpx;
}

/* 联系方式 */
.contact-wrap {
  margin-bottom: 30rpx;
}

.contact-input {
  width: 100%;
  height: 88rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

/* 提交按钮 */
.btn-submit {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #1A5D3A, #2E7D52);
  color: #fff;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 44rpx;
  border: none;
}

.btn-submit[disabled] {
  background: #ccc;
}

/* 反馈历史 */
.history-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
}

.feedback-card {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.feedback-card:last-child {
  border-bottom: none;
}

.feedback-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.feedback-category {
  font-size: 24rpx;
  color: #1A5D3A;
  background: #e8f5e9;
  padding: 4rpx 16rpx;
  border-radius: 12rpx;
}

.feedback-status {
  font-size: 24rpx;
  padding: 4rpx 16rpx;
  border-radius: 12rpx;
}

.feedback-status.pending {
  background: #f5f5f5;
  color: #999;
}

.feedback-status.processing {
  background: #e6f7ff;
  color: #1890ff;
}

.feedback-status.resolved {
  background: #f6ffed;
  color: #52c41a;
}

.feedback-status.closed {
  background: #f5f5f5;
  color: #999;
}

.feedback-content-preview {
  font-size: 28rpx;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-bottom: 8rpx;
}

.feedback-time {
  font-size: 24rpx;
  color: #ccc;
}

/* 展开详情 */
.feedback-detail {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx dashed #eee;
}

.detail-content {
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  margin-bottom: 16rpx;
  white-space: pre-wrap;
}

.reply-card {
  background: #f6ffed;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-top: 12rpx;
}

.reply-label {
  font-size: 24rpx;
  color: #52c41a;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.reply-content {
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
}

.reply-time {
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
}

.no-reply {
  font-size: 26rpx;
  color: #999;
  text-align: center;
  padding: 20rpx 0;
}

.expand-hint {
  text-align: center;
  font-size: 24rpx;
  color: #1A5D3A;
  margin-top: 12rpx;
}
