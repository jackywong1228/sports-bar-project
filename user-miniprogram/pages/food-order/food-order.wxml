<view class="container">
  <!-- 订单详情 -->
  <view class="section">
    <view class="title">订单详情</view>
    <view class="item" wx:for="{{cart}}" wx:key="id">
      <text class="item-name">{{item.name}} x{{item.quantity}}</text>
      <text class="item-price">{{item.price * item.quantity}}金币</text>
    </view>
  </view>

  <!-- 取餐方式 -->
  <view class="section">
    <view class="title">取餐方式</view>
    <radio-group class="order-type-group" bindchange="onOrderTypeChange">
      <label class="order-type-item {{orderType === 'immediate' ? 'active' : ''}}">
        <radio value="immediate" checked="{{orderType === 'immediate'}}" color="#1A5D3A" />
        <view class="type-content">
          <text class="type-name">立即取餐</text>
          <text class="type-desc">下单后尽快制作</text>
        </view>
      </label>
      <label class="order-type-item {{orderType === 'scheduled' ? 'active' : ''}}">
        <radio value="scheduled" checked="{{orderType === 'scheduled'}}" color="#1A5D3A" />
        <view class="type-content">
          <text class="type-name">预约取餐</text>
          <text class="type-desc">提前点餐，到店即取</text>
        </view>
      </label>
    </radio-group>
  </view>

  <!-- 预约时间选择（仅预约取餐时显示） -->
  <view class="section" wx:if="{{orderType === 'scheduled'}}">
    <view class="title">预约取餐时间</view>
    <view class="schedule-picker">
      <view class="picker-row">
        <text class="picker-label">取餐日期</text>
        <picker mode="selector" range="{{dateOptions}}" range-key="label" value="{{selectedDateIndex}}" bindchange="onDateChange">
          <view class="picker-value">
            {{dateOptions[selectedDateIndex].label}}
            <text class="arrow">></text>
          </view>
        </picker>
      </view>
      <view class="picker-row">
        <text class="picker-label">取餐时间</text>
        <picker mode="selector" range="{{timeOptions}}" range-key="label" value="{{selectedTimeIndex}}" bindchange="onTimeChange">
          <view class="picker-value">
            {{timeOptions[selectedTimeIndex].label}}
            <text class="arrow">></text>
          </view>
        </picker>
      </view>
    </view>
    <view class="schedule-tips">
      <text class="tips-icon">!</text>
      <text class="tips-text">请在预约时间前10分钟到店取餐</text>
    </view>
  </view>

  <!-- 备注 -->
  <view class="section">
    <view class="title">备注</view>
    <textarea class="remark" placeholder="口味偏好、过敏信息等（选填）" bindinput="onRemarkInput" value="{{remark}}"></textarea>
  </view>

  <!-- 优惠券选择 -->
  <view class="section">
    <view class="title">优惠券</view>
    <view wx:if="{{availableCoupons.length === 0}}" class="coupon-empty">暂无可用优惠券</view>
    <view
      wx:for="{{availableCoupons}}"
      wx:key="id"
      class="coupon-card {{selectedCouponIndex === index ? 'selected' : ''}}"
      bindtap="selectCoupon"
      data-index="{{index}}"
    >
      <view class="coupon-card-left">
        <text class="coupon-value" wx:if="{{item.type === 'cash'}}">{{item.discount_value}}</text>
        <text class="coupon-value" wx:elif="{{item.type === 'gift'}}">免单</text>
        <text class="coupon-unit" wx:if="{{item.type === 'cash'}}">金币</text>
      </view>
      <view class="coupon-card-right">
        <text class="coupon-name">{{item.name}}</text>
        <text class="coupon-expire">{{item.end_time}}</text>
      </view>
      <view class="coupon-check {{selectedCouponIndex === index ? 'checked' : ''}}"></view>
    </view>
  </view>

  <!-- 底部结算栏 -->
  <view class="bottom-bar">
    <view class="total-info">
      <view class="total" wx:if="{{couponDiscount > 0}}">
        实付: <text class="price">{{payAmount}}金币</text>
        <text class="original-price">{{total}}金币</text>
      </view>
      <view class="total" wx:else>合计: <text class="price">{{total}}金币</text></view>
      <view class="schedule-time" wx:if="{{orderType === 'scheduled'}}">
        {{dateOptions[selectedDateIndex].label}} {{timeOptions[selectedTimeIndex].label}} 取餐
      </view>
    </view>
    <button class="btn" bindtap="submitOrder" loading="{{submitting}}" disabled="{{submitting}}">
      {{orderType === 'scheduled' ? '预约下单' : '立即下单'}}
    </button>
  </view>

  <!-- 支付方式选择弹窗 -->
  <view class="pay-modal-mask" wx:if="{{showPayModal}}" bindtap="closePayModal">
    <view class="pay-modal" catchtap="noop">
      <view class="pay-modal-header">
        <text class="pay-modal-title">选择支付方式</text>
        <view class="pay-modal-close" bindtap="closePayModal">
          <text>X</text>
        </view>
      </view>
      <view class="pay-modal-price">
        <text class="pay-price-label">需支付</text>
        <text class="pay-price-value">{{payAmount}}</text>
        <text class="pay-price-unit">金币/元</text>
        <view class="pay-coupon-info" wx:if="{{couponDiscount > 0}}">
          <text class="coupon-discount-text">已优惠 {{couponDiscount}} 金币</text>
        </view>
      </view>
      <view class="pay-options">
        <view class="pay-option {{selectedPayType === 'coin' ? 'active' : ''}}" bindtap="selectPayType" data-type="coin">
          <view class="pay-option-icon coin-icon">$</view>
          <view class="pay-option-info">
            <text class="pay-option-name">金币支付</text>
            <text class="pay-option-desc">余额: {{coinBalance}} 金币</text>
          </view>
          <view class="pay-option-check {{selectedPayType === 'coin' ? 'checked' : ''}}"></view>
        </view>
        <view class="pay-option {{selectedPayType === 'wechat' ? 'active' : ''}}" bindtap="selectPayType" data-type="wechat">
          <view class="pay-option-icon wechat-icon">W</view>
          <view class="pay-option-info">
            <text class="pay-option-name">微信支付</text>
            <text class="pay-option-desc">使用微信直接付款</text>
          </view>
          <view class="pay-option-check {{selectedPayType === 'wechat' ? 'checked' : ''}}"></view>
        </view>
      </view>
      <button class="pay-confirm-btn" bindtap="confirmPay">确认支付</button>
    </view>
  </view>
</view>
