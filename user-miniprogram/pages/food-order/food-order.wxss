.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 160rpx;
}

.section {
  background: #fff;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.title {
  font-size: 30rpx;
  font-weight: 500;
  margin-bottom: 20rpx;
  color: #333;
}

/* 订单详情 */
.item {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  font-size: 28rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.item:last-child {
  border-bottom: none;
}

.item-name {
  color: #333;
}

.item-price {
  color: #1A5D3A;
  font-weight: 500;
}

/* 取餐方式 */
.order-type-group {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.order-type-item {
  display: flex;
  align-items: center;
  padding: 24rpx 20rpx;
  background: #f9f9f9;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.order-type-item.active {
  background: rgba(26, 93, 58, 0.1);
  border-color: #1A5D3A;
}

.type-content {
  margin-left: 16rpx;
  display: flex;
  flex-direction: column;
}

.type-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
}

.type-desc {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
}

/* 预约时间选择 */
.schedule-picker {
  background: #f9f9f9;
  border-radius: 12rpx;
  overflow: hidden;
}

.picker-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 24rpx;
  border-bottom: 1rpx solid #eee;
}

.picker-row:last-child {
  border-bottom: none;
}

.picker-label {
  font-size: 28rpx;
  color: #333;
}

.picker-value {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  color: #1A5D3A;
}

.arrow {
  margin-left: 10rpx;
  font-size: 24rpx;
  color: #999;
}

.schedule-tips {
  display: flex;
  align-items: center;
  margin-top: 20rpx;
  padding: 16rpx 20rpx;
  background: #FFF9E6;
  border-radius: 8rpx;
}

.tips-icon {
  width: 32rpx;
  height: 32rpx;
  line-height: 32rpx;
  text-align: center;
  background: #FFB800;
  color: #fff;
  border-radius: 50%;
  font-size: 20rpx;
  font-weight: bold;
  margin-right: 12rpx;
}

.tips-text {
  font-size: 24rpx;
  color: #996600;
}

/* 备注 */
.remark {
  width: 100%;
  height: 150rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  padding: 16rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

/* 底部结算栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.total-info {
  flex: 1;
}

.total {
  font-size: 28rpx;
  color: #333;
}

.price {
  font-size: 36rpx;
  color: #1A5D3A;
  font-weight: bold;
}

.schedule-time {
  font-size: 24rpx;
  color: #666;
  margin-top: 4rpx;
}

.btn {
  width: 240rpx;
  height: 80rpx;
  line-height: 80rpx;
  background: #1A5D3A;
  color: #fff;
  border-radius: 40rpx;
  font-size: 30rpx;
  border: none;
}

.btn[disabled] {
  background: #ccc;
}

/* 优惠券选择 */
.coupon-empty {
  font-size: 24rpx;
  color: #999;
  text-align: center;
  padding: 20rpx 0;
}

.coupon-card {
  display: flex;
  align-items: center;
  padding: 20rpx;
  border: 2rpx solid #eee;
  border-radius: 12rpx;
  margin-bottom: 12rpx;
  transition: all 0.2s;
}

.coupon-card.selected {
  border-color: #1A5D3A;
  background: rgba(26, 93, 58, 0.05);
}

.coupon-card-left {
  min-width: 100rpx;
  text-align: center;
  padding-right: 20rpx;
  border-right: 2rpx dashed #ddd;
  margin-right: 20rpx;
}

.coupon-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #1A5D3A;
  display: block;
}

.coupon-unit {
  font-size: 20rpx;
  color: #999;
}

.coupon-card-right {
  flex: 1;
}

.coupon-name {
  font-size: 26rpx;
  color: #333;
  display: block;
  margin-bottom: 4rpx;
}

.coupon-expire {
  font-size: 22rpx;
  color: #999;
}

.coupon-check {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  border: 2rpx solid #ddd;
  margin-left: 16rpx;
  position: relative;
  flex-shrink: 0;
}

.coupon-check.checked {
  border-color: #1A5D3A;
  background: #1A5D3A;
}

.coupon-check.checked::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 14rpx;
  height: 8rpx;
  border-left: 3rpx solid #fff;
  border-bottom: 3rpx solid #fff;
  transform: translate(-50%, -60%) rotate(-45deg);
}

.original-price {
  font-size: 24rpx;
  color: #999;
  text-decoration: line-through;
  margin-left: 10rpx;
}

/* 支付弹窗 */
.pay-modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

.pay-modal {
  width: 100%;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  padding: 40rpx 30rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

.pay-modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.pay-modal-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
}

.pay-modal-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.pay-modal-close text {
  font-size: 28rpx;
  color: #999;
}

.pay-modal-price {
  text-align: center;
  padding: 30rpx 0;
  margin-bottom: 20rpx;
}

.pay-price-label {
  font-size: 26rpx;
  color: #999;
  margin-right: 10rpx;
}

.pay-price-value {
  font-size: 56rpx;
  font-weight: bold;
  color: #1A5D3A;
}

.pay-price-unit {
  font-size: 24rpx;
  color: #999;
  margin-left: 6rpx;
}

.pay-coupon-info {
  margin-top: 8rpx;
}

.coupon-discount-text {
  font-size: 24rpx;
  color: #e64a19;
  font-weight: 500;
}

.pay-options {
  margin-bottom: 30rpx;
}

.pay-option {
  display: flex;
  align-items: center;
  padding: 24rpx 20rpx;
  border: 2rpx solid #eee;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  transition: all 0.2s;
}

.pay-option.active {
  border-color: #1A5D3A;
  background: #f0f7f2;
}

.pay-option-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
  margin-right: 20rpx;
}

.coin-icon {
  background: linear-gradient(135deg, #C9A962 0%, #DAC07A 100%);
}

.wechat-icon {
  background: linear-gradient(135deg, #07C160 0%, #06AD56 100%);
}

.pay-option-info {
  flex: 1;
}

.pay-option-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  display: block;
}

.pay-option-desc {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
  display: block;
}

.pay-option-check {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  border: 2rpx solid #ddd;
  position: relative;
}

.pay-option-check.checked {
  border-color: #1A5D3A;
  background: #1A5D3A;
}

.pay-option-check.checked::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 14rpx;
  height: 8rpx;
  border-left: 3rpx solid #fff;
  border-bottom: 3rpx solid #fff;
  transform: translate(-50%, -60%) rotate(-45deg);
}

.pay-confirm-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #1A5D3A 0%, #2E7D52 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 44rpx;
  border: none;
}

.pay-confirm-btn::after {
  border: none;
}
