.container {
  padding: 40rpx 20rpx;
  background: #F5F7F5;
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
}

.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 60rpx 40rpx;
  width: 100%;
  text-align: center;
}

.icon-area {
  margin-bottom: 40rpx;
}

.success-icon {
  width: 120rpx;
  height: 120rpx;
  line-height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #1A5D3A 0%, #2E7D52 100%);
  color: #fff;
  font-size: 60rpx;
  display: inline-block;
}

.error-icon {
  width: 120rpx;
  height: 120rpx;
  line-height: 120rpx;
  border-radius: 50%;
  background: #E74C3C;
  color: #fff;
  font-size: 60rpx;
  font-weight: bold;
  display: inline-block;
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 6rpx solid #eee;
  border-top-color: #1A5D3A;
  border-radius: 50%;
  display: inline-block;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.desc {
  display: block;
  font-size: 30rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.code-text {
  display: block;
  font-size: 26rpx;
  color: #999;
  margin-top: 16rpx;
  margin-bottom: 40rpx;
}

.actions {
  margin-top: 20rpx;
}

.btn-primary {
  width: 100%;
  background: linear-gradient(135deg, #1A5D3A 0%, #2E7D52 100%);
  color: #fff;
  border-radius: 12rpx;
  font-size: 32rpx;
  padding: 24rpx 0;
  margin-bottom: 20rpx;
}

.btn-secondary {
  width: 100%;
  background: #fff;
  color: #C9A962;
  border: 2rpx solid #C9A962;
  border-radius: 12rpx;
  font-size: 32rpx;
  padding: 24rpx 0;
}
