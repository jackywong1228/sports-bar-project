.container {
  padding: 20rpx;
  background: #F5F7F5;
  min-height: 100vh;
}

.stats-card {
  background: linear-gradient(135deg, #1A5D3A 0%, #2E7D52 100%);
  border-radius: 20rpx;
  padding: 40rpx;
  color: #fff;
  margin-bottom: 30rpx;
}

.stats-title {
  font-size: 28rpx;
  opacity: 0.8;
  margin-bottom: 30rpx;
}

.stats-row {
  display: flex;
  justify-content: space-around;
}

.stat-item {
  text-align: center;
}

.stat-num {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
}

.stat-label {
  display: block;
  font-size: 24rpx;
  opacity: 0.7;
  margin-top: 8rpx;
}

.invite-action {
  background: #fff;
  border-radius: 20rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
}

.generate-btn {
  width: 100%;
  background: #1A5D3A;
  color: #fff;
  border-radius: 12rpx;
  font-size: 32rpx;
  padding: 24rpx 0;
}

.generate-btn[disabled] {
  background: #ccc;
}

.code-display {
  margin-top: 30rpx;
  text-align: center;
  padding: 30rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
}

.code-label {
  font-size: 24rpx;
  color: #999;
  display: block;
}

.code-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #1A5D3A;
  letter-spacing: 8rpx;
  display: block;
  margin: 16rpx 0;
}

.code-actions {
  display: flex;
  justify-content: center;
  gap: 30rpx;
  margin-top: 16rpx;
}

.copy-btn {
  color: #1A5D3A;
  font-size: 28rpx;
  padding: 8rpx 24rpx;
  border: 1rpx solid #1A5D3A;
  border-radius: 8rpx;
}

.share-btn {
  background: #C9A962;
  color: #fff;
  font-size: 28rpx;
  padding: 8rpx 24rpx;
  border-radius: 8rpx;
  line-height: normal;
}

.history-section {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.history-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.history-item:last-child {
  border-bottom: none;
}

.history-code {
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
  display: block;
}

.history-time {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-top: 4rpx;
}

.status {
  font-size: 24rpx;
  padding: 4rpx 16rpx;
  border-radius: 6rpx;
}

.status-pending {
  color: #C9A962;
  background: #FFF8E8;
}

.status-used {
  color: #1A5D3A;
  background: #E8F5EE;
}

.status-expired {
  color: #999;
  background: #f5f5f5;
}

.invitee {
  font-size: 24rpx;
  color: #666;
  display: block;
  margin-top: 4rpx;
  text-align: right;
}

.empty {
  text-align: center;
  color: #999;
  padding: 60rpx 0;
  font-size: 28rpx;
}
