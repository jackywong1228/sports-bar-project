.page {
  min-height: 100vh;
  background: #F5F7F5;
  padding-bottom: env(safe-area-inset-bottom);
}

/* 状态横幅 */
.status-banner {
  background: linear-gradient(135deg, #1A5D3A, #2E7D52);
  padding: 50rpx 40rpx 40rpx;
  text-align: center;
  color: #fff;
}

.status-icon {
  font-size: 56rpx;
  margin-bottom: 12rpx;
}

.status-text {
  font-size: 40rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.status-subtitle {
  font-size: 26rpx;
  opacity: 0.85;
}

/* 核销二维码卡片 */
.qrcode-card {
  background: #fff;
  margin: 20rpx 24rpx;
  border-radius: 16rpx;
  padding: 40rpx 30rpx;
  text-align: center;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.qrcode-image {
  width: 400rpx;
  height: 400rpx;
  margin: 0 auto 20rpx;
  display: block;
}

.qrcode-tip {
  font-size: 28rpx;
  color: #1A5D3A;
  font-weight: 500;
  margin-bottom: 10rpx;
}

.qrcode-no {
  font-size: 24rpx;
  color: #999;
}

/* 已核销卡片 */
.verified-card {
  background: #fff;
  margin: 20rpx 24rpx;
  border-radius: 16rpx;
  padding: 30rpx;
  text-align: center;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.verified-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.verified-text {
  font-size: 32rpx;
  color: #1A5D3A;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.verified-time {
  font-size: 24rpx;
  color: #999;
}

/* 信息卡片 */
.info-card {
  background: #fff;
  margin: 20rpx 24rpx;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14rpx 0;
}

.info-label {
  font-size: 28rpx;
  color: #999;
  flex-shrink: 0;
  width: 160rpx;
}

.info-value {
  font-size: 28rpx;
  color: #333;
  text-align: right;
  flex: 1;
}

.order-no {
  font-size: 24rpx;
  color: #666;
  word-break: break-all;
}

.total-row {
  margin-top: 10rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.total-label {
  font-weight: 600;
  color: #333;
}

.total-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #1A5D3A;
}

/* 底部操作栏 */
.bottom-spacer {
  height: 140rpx;
}

.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  padding: 20rpx 24rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.06);
  z-index: 100;
}

.btn-cancel {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  font-size: 30rpx;
  color: #666;
  background: #f5f5f5;
  border-radius: 44rpx;
  margin-right: 20rpx;
}

.btn-pay {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  font-size: 30rpx;
  color: #fff;
  background: linear-gradient(135deg, #1A5D3A, #2E7D52);
  border-radius: 44rpx;
  font-weight: 600;
}

/* 加载状态 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 60vh;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #e0e0e0;
  border-top-color: #1A5D3A;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}

/* 空状态 */
.empty-container {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 60vh;
}

.empty-text {
  font-size: 30rpx;
  color: #999;
}
