.container {
  min-height: 100vh;
  background: #f5f5f5;
}

.header {
  background: linear-gradient(135deg, #1A5D3A, #2E7D52);
  padding: 60rpx 30rpx;
  color: #fff;
}

.level-info {
  display: flex;
  flex-direction: column;
}

.level {
  font-size: 40rpx;
  font-weight: bold;
  margin-bottom: 12rpx;
}

.expire {
  font-size: 26rpx;
  opacity: 0.8;
}

.section {
  background: #fff;
  padding: 30rpx;
  margin-top: 20rpx;
}

.title {
  font-size: 32rpx;
  font-weight: 500;
  margin-bottom: 24rpx;
}

.card-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.card {
  position: relative;
  display: flex;
  flex-direction: column;
  padding: 36rpx;
  background: #fff;
  border-radius: 20rpx;
  border: 2rpx solid #e8e8e8;
  overflow: hidden;
}

.card.recommended {
  border-color: #1A5D3A;
  background: linear-gradient(180deg, rgba(26, 93, 58, 0.06) 0%, #fff 40%);
}

.card.card-sss {
  border-color: #C9A962;
  background: linear-gradient(180deg, rgba(201, 169, 98, 0.08) 0%, #fff 40%);
}

.card-badge {
  position: absolute;
  top: 0;
  right: 30rpx;
  background: linear-gradient(135deg, #1A5D3A, #2E7D52);
  color: #fff;
  font-size: 22rpx;
  padding: 8rpx 20rpx;
  border-radius: 0 0 10rpx 10rpx;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.card-name {
  font-size: 34rpx;
  font-weight: bold;
  color: #222;
}

.card-level {
  font-size: 22rpx;
  color: #1A5D3A;
  background: rgba(26, 93, 58, 0.1);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-weight: 500;
}

.card-sss .card-level {
  color: #8B7355;
  background: rgba(201, 169, 98, 0.15);
}

/* 价格 + 有效期 行 */
.card-meta {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 28rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.card-price {
  display: flex;
  align-items: baseline;
  gap: 10rpx;
}

.card-price .price {
  font-size: 48rpx;
  font-weight: bold;
  color: #1A5D3A;
}

.card-sss .card-price .price {
  color: #8B7355;
}

.card-price .original-price {
  font-size: 26rpx;
  color: #bbb;
  text-decoration: line-through;
}

.card-duration {
  font-size: 24rpx;
  color: #999;
}

/* 权益列表 */
.card-features {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.feature-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.feature-check {
  font-size: 24rpx;
  color: #1A5D3A;
  font-weight: bold;
  flex-shrink: 0;
  width: 32rpx;
  text-align: center;
}

.card-sss .feature-check {
  color: #C9A962;
}

.feature-text {
  font-size: 26rpx;
  color: #555;
  line-height: 1.4;
}

.card-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background: linear-gradient(135deg, #1A5D3A, #2E7D52);
  color: #fff;
  font-size: 30rpx;
  font-weight: 500;
  border-radius: 44rpx;
}

.card.recommended .card-btn {
  background: linear-gradient(135deg, #1A5D3A, #145030);
}

.card-sss .card-btn {
  background: linear-gradient(135deg, #8B7355, #C9A962);
}

.benefits-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.benefit-item {
  width: calc(50% - 8rpx);
  background: #f5f7f5;
  border-radius: 12rpx;
  padding: 24rpx;
  text-align: center;
  box-sizing: border-box;
}

.benefit-value {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #1A5D3A;
}

.benefit-label {
  display: block;
  font-size: 24rpx;
  color: #666;
  margin-top: 8rpx;
}

/* 当前等级权益描述 */
.benefits-desc {
  font-size: 26rpx;
  color: #888;
  margin-bottom: 20rpx;
  line-height: 1.5;
}

/* 当前等级权益标签 */
.benefits-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.benefit-tag {
  font-size: 24rpx;
  color: #1A5D3A;
  background: rgba(26, 93, 58, 0.08);
  padding: 10rpx 20rpx;
  border-radius: 8rpx;
  line-height: 1.4;
}

/* SSS 专属权益区 */
.sss-benefits .sss-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.sss-benefits .sss-item {
  width: calc(33.33% - 12rpx);
  text-align: center;
  padding: 20rpx 8rpx;
  background: linear-gradient(135deg, rgba(201, 169, 98, 0.08), rgba(201, 169, 98, 0.02));
  border-radius: 12rpx;
  font-size: 24rpx;
  color: #8B7355;
  box-sizing: border-box;
}

/* 邀请区域 */
.invite-info {
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 28rpx;
  color: #555;
}

.invite-btn {
  display: inline-block;
  padding: 12rpx 32rpx;
  background: linear-gradient(135deg, #1A5D3A, #2E7D52);
  color: #fff;
  font-size: 26rpx;
  border-radius: 30rpx;
}

.empty {
  text-align: center;
  padding: 60rpx 40rpx;
  color: #999;
  font-size: 28rpx;
}
