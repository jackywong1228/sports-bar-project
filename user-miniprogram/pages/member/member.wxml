<view class="container">
  <!-- 当前会员信息 -->
  <view class="header">
    <view class="level-info">
      <text class="level">{{benefits.title}}</text>
      <text class="expire" wx:if="{{isMember && memberInfo.member_expire_time}}">有效期至：{{memberInfo.member_expire_time}}</text>
      <text class="expire" wx:elif="{{isMember}}">长期有效</text>
      <text class="expire" wx:else>开通SS/SSS会员享受更多权益</text>
    </view>
  </view>

  <!-- 当前等级权益展示 -->
  <view class="section">
    <view class="title">{{benefits.title}} 权益</view>
    <view class="benefits-desc">{{benefits.description}}</view>
    <view class="benefits-list">
      <view class="benefit-tag" wx:for="{{benefits.features}}" wx:key="text">
        <text>{{item.text}}</text>
      </view>
    </view>
  </view>

  <!-- SSS展示型权益 -->
  <view class="section sss-benefits" wx:if="{{currentLevel === 'SSS' && memberInfo.display_benefits && memberInfo.display_benefits.length > 0}}">
    <view class="title">SSS专属权益</view>
    <view class="sss-grid">
      <view class="sss-item" wx:for="{{memberInfo.display_benefits}}" wx:key="*this">
        <text>{{item}}</text>
      </view>
    </view>
  </view>

  <!-- 邀请信息 -->
  <view class="section invite-section" wx:if="{{isMember && memberInfo.monthly_invite_remaining !== undefined}}">
    <view class="title">邀请朋友</view>
    <view class="invite-info">
      <text>本月剩余邀请次数：{{memberInfo.monthly_invite_remaining}}次</text>
      <navigator url="/pages/invite/invite" class="invite-btn">去邀请</navigator>
    </view>
  </view>

  <!-- 会员卡套餐列表 -->
  <view class="section">
    <view class="title">{{isMember ? '续费/升级会员' : '开通会员'}}</view>
    <view class="card-list">
      <view class="card {{item.is_recommended ? 'recommended' : ''}} {{item.level_name === 'SSS级会员' ? 'card-sss' : ''}}" wx:for="{{cards}}" wx:key="id" bindtap="buyCard" data-id="{{item.id}}">
        <view class="card-badge" wx:if="{{item.is_recommended}}">推荐</view>
        <view class="card-header">
          <text class="card-name">{{item.name}}</text>
          <text class="card-level">{{item.level_name}}</text>
        </view>
        <view class="card-meta">
          <view class="card-price">
            <text class="price">¥{{item.price}}</text>
            <text class="original-price" wx:if="{{item.original_price > item.price}}">¥{{item.original_price}}</text>
          </view>
          <text class="card-duration">有效期 {{item.duration_days}} 天</text>
        </view>
        <view class="card-features" wx:if="{{item.highlights && item.highlights.length > 0}}">
          <view class="feature-item" wx:for="{{item.highlights}}" wx:for-item="hl" wx:key="*this">
            <text class="feature-check">✓</text>
            <text class="feature-text">{{hl}}</text>
          </view>
        </view>
        <view class="card-btn">立即开通</view>
      </view>
    </view>
    <view class="empty" wx:if="{{cards.length === 0}}">
      <text>暂无可购买的套餐</text>
    </view>
  </view>
</view>
