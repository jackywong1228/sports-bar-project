.container {
  min-height: 100vh;
  background: #f5f5f5;
}

/* Tab 栏 */
.tab-bar {
  display: flex;
  background: #fff;
  padding: 20rpx 30rpx;
  border-bottom: 1rpx solid #eee;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 28rpx;
  color: #666;
  border-radius: 30rpx;
  transition: all 0.2s;
}

.tab-item.active {
  background: #1A5D3A;
  color: #fff;
}

/* 列表 */
.team-list {
  padding: 20rpx;
}

.team-card {
  background: #fff;
  padding: 30rpx;
  margin-bottom: 20rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.sport-badge {
  display: inline-block;
  padding: 8rpx 20rpx;
  font-size: 24rpx;
  border-radius: 20rpx;
  color: #fff;
}

.sport-badge.golf {
  background: linear-gradient(135deg, #43cea2, #185a9d);
}

.sport-badge.pickleball {
  background: linear-gradient(135deg, #f093fb, #f5576c);
}

.sport-badge.tennis {
  background: linear-gradient(135deg, #4facfe, #00f2fe);
}

.sport-badge.squash {
  background: linear-gradient(135deg, #fa709a, #fee140);
}

.status-tag {
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
}

.status-tag.recruiting {
  background: #e6f7ff;
  color: #1890ff;
}

.status-tag.full {
  background: #fff7e6;
  color: #fa8c16;
}

.status-tag.completed {
  background: #f6ffed;
  color: #52c41a;
}

.status-tag.cancelled {
  background: #f5f5f5;
  color: #999;
}

.status-tag.expired {
  background: #f0f0f0;
  color: #8c8c8c;
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.card-meta {
  margin-bottom: 20rpx;
}

.meta-row {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.meta-icon {
  margin-right: 8rpx;
}

.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.member-info {
  display: flex;
  align-items: baseline;
}

.member-count {
  font-size: 36rpx;
  font-weight: bold;
  color: #1A5D3A;
}

.member-label {
  font-size: 24rpx;
  color: #999;
  margin-left: 4rpx;
}

.role-tag {
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
}

.role-tag.creator {
  background: #fff7e6;
  color: #C9A962;
}

.role-tag.member {
  background: #e6f7ff;
  color: #1890ff;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-icon {
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 30rpx;
  opacity: 0.5;
}

.empty-text {
  color: #999;
  font-size: 28rpx;
  margin-bottom: 30rpx;
}

.btn-go-square {
  width: 300rpx;
  height: 76rpx;
  line-height: 76rpx;
  background: linear-gradient(135deg, #1A5D3A, #2E7D52);
  color: #fff;
  font-size: 28rpx;
  border-radius: 38rpx;
  border: none;
}

/* 加载提示 */
.loading-tip {
  text-align: center;
  padding: 40rpx;
  color: #999;
  font-size: 28rpx;
}

.no-more {
  text-align: center;
  padding: 30rpx;
  color: #ccc;
  font-size: 24rpx;
}
