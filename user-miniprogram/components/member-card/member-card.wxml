<!-- 会员卡片组件 -->
<view
  class="member-card level-{{currentLevel}}"
  style="background: {{currentTheme.gradient}};"
  bindtap="onCardTap"
>
  <!-- 卡片顶部 -->
  <view class="card-header">
    <view class="level-info">
      <view class="level-badge">
        <text class="level-text">{{currentTheme.name}}</text>
      </view>
    </view>
    <view class="upgrade-btn" wx:if="{{currentLevel === 'S'}}" catchtap="onUpgradeTap">
      <text>升级</text>
    </view>
  </view>

  <!-- 卡片内容 -->
  <view class="card-body" wx:if="{{showDetail}}">
    <!-- 会员权益概览 -->
    <view class="benefits-row">
      <view class="benefit-item">
        <text class="benefit-value">{{quotaInfo.daily}}</text>
        <text class="benefit-label">日预约额度</text>
      </view>
      <view class="benefit-divider"></view>
      <view class="benefit-item">
        <text class="benefit-value">{{quotaInfo.remaining}}</text>
        <text class="benefit-label">今日剩余</text>
      </view>
    </view>

    <!-- S级会员提示 -->
    <view class="trial-tip" wx:if="{{currentLevel === 'S'}}">
      <text class="tip-icon">💡</text>
      <text class="tip-text">升级会员可自主预约场馆</text>
    </view>
  </view>

  <!-- 简洁模式 -->
  <view class="card-simple" wx:if="{{!showDetail}}">
    <text class="simple-text">{{currentLevel === 'S' ? '免费会员' : '有效期至 ' + (memberInfo.expire_date || '永久')}}</text>
  </view>

  <!-- 装饰元素 -->
  <view class="card-decoration">
    <view class="decoration-circle circle-1"></view>
    <view class="decoration-circle circle-2"></view>
  </view>
</view>
